# 复制为 wrangler.toml 后在本目录执行 wrangler deploy
name = "microbe-chat-proxy"
main = "microbe-chat-proxy.mjs"
compatibility_date = "2024-01-01"

# wrangler secret put OPENAI_API_KEY
# 可选变量（控制台或 [vars]）：
# OPENAI_MODEL = "gpt-4o-mini"
# 使用 DeepSeek 时示例：
# UPSTREAM_CHAT_URL = "https://api.deepseek.com/chat/completions"
# OPENAI_MODEL = "deepseek-chat"
# ALLOWED_ORIGINS = "https://small-apple-sun.github.io,http://127.0.0.1:8878"
# TRUST_CLIENT_KEYS = "1"   仅自建可信代理：允许请求体 openaiApiKey 覆盖上游密钥（公开展示勿开）
